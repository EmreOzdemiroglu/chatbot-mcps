PORT=7879

# Default working directory for OMP sessions (absolute path recommended)
# MCP_ROOT=/home/you/code/my-project

# Bearer token (auto-generated into ~/.chatgpt-omp-as-mcp/.env)
# MCP_API_KEY=omp-mcp-xxxxxxxx

# ChatGPT "No authentication" while testing connectors
# MCP_NO_AUTH=1

# MCP_NO_TUNNEL=1
# MCP_NO_DOWNLOAD_CLOUDFLARED=1

# OMP binary
# MCP_OMP_BIN=/home/you/.local/bin/omp

# Default max seconds per prompt
# MCP_OMP_TIMEOUT_SEC=600

# Allow --cwd outside MCP_ROOT
# MCP_OMP_ALLOW_ANY_CWD=1

# Default model when ChatGPT omits model= (empty = OMP config default)
# MCP_OMP_DEFAULT_MODEL=xai-oauth/grok-4.5
